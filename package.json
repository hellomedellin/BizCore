{
  "name": "bizcore",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter @bizcore/api-server dev & pnpm --filter @bizcore/web dev",
    "build": "pnpm --filter @bizcore/db build && pnpm --filter @bizcore/api-server build && pnpm --filter @bizcore/web build",
    "db:push": "pnpm --filter @bizcore/db db:push",
    "db:generate": "pnpm --filter @bizcore/db db:generate",
    "db:seed": "pnpm --filter @bizcore/db db:seed",
    "codegen": "pnpm --filter @bizcore/api-spec codegen"
  },
  "devDependencies": {
    "typescript": "^5.9.0"
  }
}

NODE_ENV=development
PORT=3000

# PostgreSQL (AWS RDS)
DATABASE_URL=postgresql://user:password@localhost:5432/bizcore

# Clerk Authentication
CLERK_SECRET_KEY=sk_test_xxx
CLERK_PUBLISHABLE_KEY=pk_test_xxx

# AWS
AWS_REGION=us-east-1
